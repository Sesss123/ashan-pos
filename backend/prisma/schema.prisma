generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        String    @id @default(uuid())
  name      String
  email     String    @unique
  password  String
  role      String    // Cashier, Waiter, Kitchen, Admin
  isActive  Boolean   @default(true)
  isDeleted Boolean   @default(false)
  deletedAt DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  sessions        Session[]
  devices         Device[]
  loginHistories  LoginHistory[]
  orders          Order[]
}

model Session {
  id        String   @id @default(uuid())
  userId    String
  token     String   @unique
  deviceIp  String?
  userAgent String?
  expiresAt DateTime
  createdAt DateTime @default(now())
  
  user      User     @relation(fields: [userId], references: [id])

  @@index([userId, token])
}

model Device {
  id        String   @id @default(uuid())
  userId    String
  deviceId  String   @unique
  os        String?
  browser   String?
  lastIp    String?
  lastLogin DateTime @default(now())
  isTrusted Boolean  @default(false)

  user      User     @relation(fields: [userId], references: [id])

  @@index([userId, deviceId])
}

model LoginHistory {
  id        String   @id @default(uuid())
  userId    String
  ipAddress String
  userAgent String
  status    String   // SUCCESS, FAILED
  createdAt DateTime @default(now())

  user      User     @relation(fields: [userId], references: [id])

  @@index([userId, createdAt])
}

model Category {
  id        String    @id @default(uuid())
  name      String
  isActive  Boolean   @default(true)
  isDeleted Boolean   @default(false)
  deletedAt DateTime?
  
  products  Product[]

  @@index([isActive, isDeleted])
}

model Product {
  id         String    @id @default(uuid())
  categoryId String
  name       String
  price      Float
  barcode    String?
  isActive   Boolean   @default(true)
  isDeleted  Boolean   @default(false)
  deletedAt  DateTime?

  category   Category  @relation(fields: [categoryId], references: [id])
  orderItems OrderItem[]

  @@index([categoryId, isActive])
}

model Order {
  id         String      @id @default(uuid())
  userId     String      // Cashier or Waiter
  tableId    String?     
  status     String      // Pending, Completed, Cancelled
  total      Float
  type       String      // Dining, Takeaway, Delivery
  isDeleted  Boolean     @default(false)
  deletedAt  DateTime?
  createdAt  DateTime    @default(now())

  user       User        @relation(fields: [userId], references: [id])
  table      Table?      @relation(fields: [tableId], references: [id])
  items      OrderItem[]
  payments   Payment[]
  receipts   Receipt[]
  kitchenOrders KitchenOrder[]

  @@index([status, createdAt])
  @@index([userId, type])
}

model OrderItem {
  id        String  @id @default(uuid())
  orderId   String
  productId String
  quantity  Int
  price     Float

  order     Order   @relation(fields: [orderId], references: [id])
  product   Product @relation(fields: [productId], references: [id])

  @@index([orderId, productId])
}

model Payment {
  id        String   @id @default(uuid())
  orderId   String
  amount    Float
  method    String   // Cash, Card
  createdAt DateTime @default(now())

  order     Order    @relation(fields: [orderId], references: [id])

  @@index([method, createdAt])
}

model Receipt {
  id        String   @id @default(uuid())
  orderId   String
  receiptNo String   @unique
  createdAt DateTime @default(now())

  order     Order    @relation(fields: [orderId], references: [id])

  @@index([receiptNo])
}

model Table {
  id        String  @id @default(uuid())
  name      String
  status    String  // Available, Occupied, Cleaning
  orders    Order[]

  @@index([status])
}

model KitchenOrder {
  id        String   @id @default(uuid())
  orderId   String
  status    String   // Pending, Preparing, Ready, Completed
  createdAt DateTime @default(now())

  order     Order    @relation(fields: [orderId], references: [id])

  @@index([status, createdAt])
}

model InventoryItem {
  id        String   @id @default(uuid())
  name      String
  quantity  Int
  minStock  Int

  movements InventoryMovement[]

  @@index([quantity])
}

model InventoryMovement {
  id        String        @id @default(uuid())
  itemId    String
  type      String        // IN, OUT
  quantity  Int
  createdAt DateTime      @default(now())

  item      InventoryItem @relation(fields: [itemId], references: [id])

  @@index([itemId, type])
}

model Supplier {
  id        String   @id @default(uuid())
  name      String
  contact   String
  orders    PurchaseOrder[]
}

model PurchaseOrder {
  id         String   @id @default(uuid())
  supplierId String
  status     String
  createdAt  DateTime @default(now())

  supplier   Supplier @relation(fields: [supplierId], references: [id])
  items      PurchaseItem[]

  @@index([supplierId, status])
}

model PurchaseItem {
  id        String @id @default(uuid())
  orderId   String
  itemName  String
  quantity  Int
  cost      Float

  order     PurchaseOrder @relation(fields: [orderId], references: [id])
}

model Customer {
  id        String   @id @default(uuid())
  name      String
  phone     String   @unique
  credit    Float    @default(0)

  @@index([phone])
}

model Notification {
  id        String   @id @default(uuid())
  message   String
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([isRead, createdAt])
}

model AuditLog {
  id        String   @id @default(uuid())
  userId    String?
  action    String
  details   String
  ipAddress String?
  createdAt DateTime @default(now())

  @@index([userId, action, createdAt])
}
