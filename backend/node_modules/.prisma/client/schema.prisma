generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// Phase 1: Authentication & User Management

model User {
  id        String   @id @default(uuid())
  email     String   @unique
  password  String
  name      String
  phone     String?
  branchId  String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  branch   Branch?    @relation(fields: [branchId], references: [id])
  roles    UserRole[]
  sessions Session[]
  devices  Device[]
  orders   Order[] // Phase 2
}

model Role {
  id          String  @id @default(uuid())
  name        String  @unique // SuperAdmin, BranchManager, Cashier, etc.
  description String?

  users       UserRole[]
  permissions RolePermission[]
}

model Permission {
  id     String @id @default(uuid())
  name   String @unique // e.g., 'CREATE_ORDER', 'MANAGE_USERS'
  module String

  roles RolePermission[]
}

model UserRole {
  userId String
  roleId String

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  role Role @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@id([userId, roleId])
}

model RolePermission {
  roleId       String
  permissionId String

  role       Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@id([roleId, permissionId])
}

model Branch {
  id             String   @id @default(uuid())
  name           String
  location       String?
  contactDetails String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  users  User[]
  orders Order[] // Phase 2
}

model Session {
  id           String   @id @default(uuid())
  userId       String
  refreshToken String   @unique
  expiresAt    DateTime
  isValid      Boolean  @default(true)
  deviceId     String?
  createdAt    DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Device {
  id         String   @id @default(uuid())
  userId     String
  deviceName String?
  ipAddress  String?
  userAgent  String?
  lastActive DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// Phase 2: POS & Billing System

model Order {
  id             String   @id @default(uuid())
  branchId       String
  userId         String
  customerId     String? // Can be linked to a Customer model later
  type           String // Dining, Takeaway, Delivery
  status         String // Pending, Completed, Cancelled, Hold
  subtotal       Float
  taxAmount      Float    @default(0)
  discountAmount Float    @default(0)
  serviceCharge  Float    @default(0)
  total          Float
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  branch    Branch      @relation(fields: [branchId], references: [id])
  user      User        @relation(fields: [userId], references: [id])
  items     OrderItem[]
  payments  Payment[]
  discounts Discount[]
  receipt   Receipt?
}

model OrderItem {
  id        String @id @default(uuid())
  orderId   String
  productId String // Linked to Product model
  quantity  Int
  unitPrice Float
  subtotal  Float

  order Order @relation(fields: [orderId], references: [id], onDelete: Cascade)
}

model Payment {
  id        String   @id @default(uuid())
  orderId   String
  amount    Float
  method    String // Cash, Card, Split
  status    String // Completed, Pending
  createdAt DateTime @default(now())

  order   Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  receipt Receipt?
}

model Discount {
  id      String @id @default(uuid())
  orderId String
  name    String
  type    String // Percentage, Fixed
  value   Float

  order Order @relation(fields: [orderId], references: [id], onDelete: Cascade)
}

model Tax {
  id   String @id @default(uuid())
  name String
  rate Float // e.g., 10 for 10%
}

model Receipt {
  id            String   @id @default(uuid())
  orderId       String   @unique
  paymentId     String?  @unique
  receiptNumber String   @unique
  printedAt     DateTime @default(now())

  order   Order    @relation(fields: [orderId], references: [id])
  payment Payment? @relation(fields: [paymentId], references: [id])
}
